# ─── Instagram / Meta ───────────────────────────────────────────────
# Your Instagram Graph API access token (long-lived page token)
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here

# Instagram Business Account ID
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# Webhook verify token — pick any random string, set same value in Meta dashboard
WEBHOOK_VERIFY_TOKEN=my_super_secret_verify_token_123

# App Secret from Meta App dashboard (used to verify webhook signatures)
META_APP_SECRET=your_meta_app_secret_here

# ─── Server ─────────────────────────────────────────────────────────
PORT=3000

# ─── Keep-alive (prevents Render free tier spin-down) ───────────────
# The public URL of your deployed Render service
RENDER_EXTERNAL_URL=https://your-app-name.onrender.com

# How often to ping self in minutes (default: 13 — just under Render's 15-min limit)
KEEPALIVE_INTERVAL_MINUTES=13

# ─── Rate limiting ───────────────────────────────────────────────────
# Max DMs per user per hour (prevent duplicate spam)
DM_COOLDOWN_MINUTES=60

# ─── Optional: Admin UI password ────────────────────────────────────
ADMIN_PASSWORD=changeme
